# Email Configuration (SMTP)
# Gmail - Use App Password (not regular password)
# 1. Enable 2FA on Gmail: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below (without spaces)

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=noreply@moviemagic.com

# Or use Outlook/Hotmail
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@outlook.com
# MAIL_PASSWORD=your_password

# Or use SendGrid
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key

# AWS Configuration (Optional - for DynamoDB if needed)
AWS_REGION=us-east-1
USERS_TABLE_NAME=MovieMagic_Users
BOOKINGS_TABLE_NAME=MovieMagic_Bookings

# Flask Configuration
FLASK_ENV=development
PORT=5000
